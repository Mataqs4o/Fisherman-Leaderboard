@model Fisherman_Board.ViewModels.HomeDashboardViewModel
@{
    ViewData["Title"] = "Оперативно табло";
}

<section class="hero-panel">
    <div class="hero-copy">
        <span class="eyebrow">Fisherman</span>
        <h1>One operating surface for boats, catches and live fishing reports.</h1>
        <p>
            Built to feel fast, clear and focused: direct access to reporting, clean registry tables
            and a simple workflow for the people who run the data every day.
        </p>

        <div class="hero-actions">
            <a class="btn btn-primary-soft" asp-controller="Reports" asp-action="Index">Open reports</a>
            <a class="btn btn-ghost-dark" asp-controller="Registry" asp-action="Index">Open registry</a>
        </div>
    </div>

    <aside class="hero-aside">
        <div class="mini-panel">
            <span class="mini-label">Аналитичен акцент</span>
            <strong>@(string.IsNullOrWhiteSpace(Model.TopInsight) ? "Добавете данни, за да видите лидерите." : Model.TopInsight)</strong>
        </div>
        <div class="mini-panel">
            <span class="mini-label">Оперативно известие</span>
            <strong>@(string.IsNullOrWhiteSpace(Model.AlertInsight) ? "Сроковете на разрешителните ще се появят тук." : Model.AlertInsight)</strong>
        </div>
    </aside>
</section>

@if (!Model.DatabaseAvailable)
{
    <section class="content-card empty-state-card">
        <h2>Базата данни не е достъпна</h2>
        <p>
            Приложението е готово, но към момента няма връзка с конфигурираната SQL база.
            След като връзката и таблиците са налични, таблото, справките и регистрите ще започнат да показват реални данни.
        </p>
    </section>
}
else
{
    <section class="metrics-grid">
        <article class="metric-card">
            <span>Кораби</span>
            <strong>@Model.TotalVessels</strong>
            <p>Регистрирани риболовни кораби.</p>
        </article>
        <article class="metric-card">
            <span>Активни разрешителни</span>
            <strong>@Model.ActivePermits</strong>
            <p>Разрешителни с текуща валидност.</p>
        </article>
        <article class="metric-card">
            <span>Излети тази година</span>
            <strong>@Model.TripsThisYear</strong>
            <p>Излети, стартирали от началото на годината.</p>
        </article>
        <article class="metric-card">
            <span>Любителски билети</span>
            <strong>@Model.RecreationalTickets</strong>
            <p>Активни билети за любителски риболов.</p>
        </article>
    </section>
}

<section class="section-shell">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Задача 2</span>
            <h2>Оперативни справки</h2>
        </div>
        <a asp-controller="Reports" asp-action="Index">Всички справки</a>
    </div>

    <div class="card-grid">
        @foreach (var card in Model.ReportCards)
        {
            <article class="content-card">
                <h3>@card.Title</h3>
                <p>@card.Description</p>
                <a class="text-link" asp-controller="@card.Controller" asp-action="@card.Action">Отвори изглед</a>
            </article>
        }
    </div>
</section>

<section class="section-shell">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Задача 3</span>
            <h2>Редакция на данни</h2>
        </div>
        <a asp-controller="Registry" asp-action="Index">Към регистрите</a>
    </div>

    <div class="card-grid">
        @foreach (var card in Model.RegistryCards)
        {
            <article class="content-card">
                <h3>@card.Title</h3>
                <p>@card.Description</p>
                <a class="text-link" asp-controller="@card.Controller" asp-action="@card.Action">Отвори регистъра</a>
            </article>
        }
    </div>
</section>
