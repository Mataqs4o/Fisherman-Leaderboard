@model Fisherman_Board.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Log in";
}

<section class="auth-stage">
    <div class="auth-story">
        <span class="eyebrow">Fisherman</span>
        <h1>Welcome back.</h1>
        <p>
            Sign in to manage boats, update catches and move through the reporting workspace without friction.
        </p>

        <div class="auth-highlights">
            <article class="auth-highlight-card">
                <strong>Focused</strong>
                <span>Quick access to the three core tables and the live report views.</span>
            </article>
            <article class="auth-highlight-card">
                <strong>Readable</strong>
                <span>Clear layouts, high-contrast forms and fewer decisions on the critical path.</span>
            </article>
            <article class="auth-highlight-card">
                <strong>Operational</strong>
                <span>Built for daily data work, not for demo-only navigation.</span>
            </article>
        </div>
    </div>

    <div class="auth-card">
        <div class="auth-card-head">
            <span class="auth-kicker">Account access</span>
            <h2>Log in to Fisherman</h2>
            <p>Use your email and password to continue.</p>
        </div>

        <form method="post" class="auth-form">
            <input asp-for="ReturnUrl" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="auth-field">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control auth-input" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control auth-input" autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <label class="checkbox-wrap auth-checkbox">
                <input asp-for="RememberMe" />
                <span>Keep me signed in on this device</span>
            </label>

            <button type="submit" class="btn btn-auth-primary">Log in</button>
        </form>

        <div class="auth-meta">
            <span>New here?</span>
            <a asp-action="Register">Create an account</a>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
