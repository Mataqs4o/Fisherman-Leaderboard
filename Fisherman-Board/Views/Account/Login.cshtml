@model Fisherman_Board.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Вход";
}

<section class="auth-stage" data-reveal="0">
    <div class="auth-story">
        <span class="eyebrow">Fisherman access</span>
        <h1>Добре дошъл обратно в работната среда.</h1>
        <p>
            Влез, за да продължиш с регистрите, улова и оперативните справки в един по-чист и по-спокоен интерфейс.
        </p>

        <div class="auth-illustration-shell" data-parallax>
            <img class="auth-illustration" src="~/images/auth-beacon.svg" alt="Илюстрация за достъп до Fisherman" />
        </div>

        <div class="auth-highlights">
            <article class="auth-highlight-card">
                <strong>Ясен вход</strong>
                <span>Бърз достъп до трите основни таблици и аналитичните екрани.</span>
            </article>
            <article class="auth-highlight-card">
                <strong>По-малко шум</strong>
                <span>Формите са по-четими и подреждат най-важното в първия поглед.</span>
            </article>
            <article class="auth-highlight-card">
                <strong>Готово за работа</strong>
                <span>Създадено за ежедневна оперативна употреба, не само за демонстрация.</span>
            </article>
        </div>
    </div>

    <div class="auth-card">
        <div class="auth-card-head">
            <span class="auth-kicker">Account access</span>
            <h2>Вход в Fisherman</h2>
            <p>Използвай имейл и парола, за да продължиш.</p>
        </div>

        <form method="post" class="auth-form">
            <input asp-for="ReturnUrl" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="auth-field">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control auth-input" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control auth-input" autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <label class="checkbox-wrap auth-checkbox">
                <input asp-for="RememberMe" />
                <span>Запомни ме на това устройство</span>
            </label>

            <button type="submit" class="btn btn-auth-primary">Вход</button>
        </form>

        <div class="auth-meta">
            <span>Нямаш профил?</span>
            <a asp-action="Register">Създай акаунт</a>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
