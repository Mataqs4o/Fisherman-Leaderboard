@model Fisherman_Board.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
}

<section class="auth-stage" data-reveal="0">
    <div class="auth-story">
        <span class="eyebrow">Fisherman onboarding</span>
        <h1>Създай достъп до системата без излишни стъпки.</h1>
        <p>
            Регистрацията е кратка и ясна, за да може нов оператор да влезе в системата и да започне работа веднага.
        </p>

        <div class="auth-illustration-shell" data-parallax>
            <img class="auth-illustration" src="~/images/auth-beacon.svg" alt="Илюстрация за регистрация във Fisherman" />
        </div>

        <div class="auth-highlights">
            <article class="auth-highlight-card">
                <strong>Бързо включване</strong>
                <span>Само необходимото за създаване на защитен профил.</span>
            </article>
            <article class="auth-highlight-card">
                <strong>Единен стил</strong>
                <span>Същата визуална логика като таблото, справките и регистрите.</span>
            </article>
            <article class="auth-highlight-card">
                <strong>Готово за работа</strong>
                <span>След регистрацията продължаваш директно към Fisherman.</span>
            </article>
        </div>
    </div>

    <div class="auth-card">
        <div class="auth-card-head">
            <span class="auth-kicker">New account</span>
            <h2>Регистрация във Fisherman</h2>
            <p>Създай профил с имейл и сигурна парола.</p>
        </div>

        <form method="post" class="auth-form">
            <input asp-for="ReturnUrl" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="auth-field">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control auth-input" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control auth-input" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="auth-field">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" class="form-control auth-input" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-auth-primary">Създай акаунт</button>
        </form>

        <div class="auth-meta">
            <span>Вече имаш достъп?</span>
            <a asp-action="Login">Влез в профила си</a>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
