@model ErrorViewModel
@{
    ViewData["Title"] = "Грешка";
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Системно съобщение</span>
        <h1>Възникна грешка при обработката на заявката</h1>
    </div>
    <p>Проверете въведените данни или конфигурацията на приложението и опитайте отново.</p>
</section>

<section class="content-card prose-card">
    @if (Model.ShowRequestId)
    {
        <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
    }

    <p>
        Ако работите локално, стартирайте приложението в среда <strong>Development</strong>,
        за да видите разширена диагностична информация.
    </p>
</section>
