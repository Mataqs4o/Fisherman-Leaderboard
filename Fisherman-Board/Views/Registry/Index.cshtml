@model Fisherman_Board.ViewModels.RegistryIndexViewModel
@{
    ViewData["Title"] = "Регистри";
}

<section class="page-header-card split-header" data-reveal="0">
    <div class="split-header-copy">
        <span class="eyebrow">Регистърна зона</span>
        <h1>Редакция на основните таблици в по-чист и по-ясен интерфейс.</h1>
        <p>
            Тук е работната зона за преглед, търсене, добавяне, редакция и изтриване
            на трите основни таблици: fisherman, лодки и улов.
        </p>
    </div>

    <aside class="split-header-aside">
        <div class="stat-orb">
            <span>3</span>
            <small>основни таблици</small>
        </div>
        <div class="mini-panel">
            <span class="mini-label">Поток</span>
            <strong>Всяка карта отвежда директно до таблицата с търсене, добавяне и редакция.</strong>
        </div>
    </aside>
</section>

@if (!Model.DatabaseAvailable)
{
    <section class="content-card empty-state-card" data-reveal="1">
        <h2>Базата данни не е достъпна</h2>
        <p>След като базата данни е налична, тук ще могат да се редактират записите в регистрите.</p>
    </section>
}
else
{
    <section class="metrics-grid" data-reveal="1">
        <article class="metric-card">
            <span>Fisherman</span>
            <strong>@Model.FishermenCount</strong>
            <p>Записи за рибари.</p>
        </article>
        <article class="metric-card">
            <span>Лодки</span>
            <strong>@Model.BoatsCount</strong>
            <p>Налични записи за лодки.</p>
        </article>
        <article class="metric-card">
            <span>Улов</span>
            <strong>@Model.CatchesCount</strong>
            <p>Записи за улов в системата.</p>
        </article>
    </section>
}

<section class="card-grid" data-reveal="2">
    <article class="content-card feature-card">
        <span class="card-kicker">Таблица 1</span>
        <h3>Fisherman</h3>
        <p>Таблица с рибари, дата на раждане и помощни атрибути за билети и разрешителни.</p>
        <div class="feature-meta">
            <a class="text-link" asp-action="Fishermen">Отвори таблицата</a>
            <span>Пълен CRUD поток</span>
        </div>
    </article>
    <article class="content-card feature-card">
        <span class="card-kicker">Таблица 2</span>
        <h3>Лодки</h3>
        <p>Таблица с лодки и техническите им характеристики за оперативни справки.</p>
        <div class="feature-meta">
            <a class="text-link" asp-action="Boats">Отвори таблицата</a>
            <span>Технически данни и редакция</span>
        </div>
    </article>
    <article class="content-card feature-card">
        <span class="card-kicker">Таблица 3</span>
        <h3>Улов</h3>
        <p>Таблица с улов по вид риба, количество и свързан излет.</p>
        <div class="feature-meta">
            <a class="text-link" asp-action="Catches">Отвори таблицата</a>
            <span>Бързо търсене и история</span>
        </div>
    </article>
</section>
