@model IEnumerable<Fisherman_Board.Models.CatchRecord>
@{
    ViewData["Title"] = "Улов";
    var search = ViewData["Search"]?.ToString() ?? string.Empty;
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Таблица 3</span>
        <h1>Улов</h1>
    </div>
    <p>Таблица с уловите по вид риба, количество и свързана лодка.</p>
</section>

<section class="toolbar-card">
    <form class="search-form" method="get">
        <input type="search" name="search" value="@search" placeholder="Търсене по вид риба или лодка" />
        <button type="submit" class="btn btn-primary-soft">Търси</button>
        <a class="btn btn-ghost" asp-action="Catches">Изчисти</a>
    </form>
    <div class="toolbar-actions">
        <a class="btn btn-primary-soft" asp-action="CreateCatch">Добави улов</a>
        <a class="btn btn-ghost" asp-action="Index">Назад</a>
    </div>
</section>

@if (!Model.Any())
{
    <section class="content-card empty-state-card">
        <h2>Няма записи</h2>
        <p>Добавете първия запис за улов в таблицата.</p>
    </section>
}
else
{
    <section class="table-card">
        <table class="table table-app">
            <thead>
                <tr>
                    <th>Вид риба</th>
                    <th>Количество</th>
                    <th>Лодка</th>
                    <th>Излет</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var catchRecord in Model)
            {
                <tr>
                    <td>@catchRecord.Species</td>
                    <td>@catchRecord.QuantityKg.ToString("F2") кг</td>
                    <td>@catchRecord.FishingTrip.FishingVessel.Marking</td>
                    <td>@catchRecord.FishingTrip.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <div class="table-actions">
                            <a class="btn btn-row" asp-action="EditCatch" asp-route-id="@catchRecord.Id">Редакция</a>
                            <form asp-action="DeleteCatch" asp-route-id="@catchRecord.Id" method="post" onsubmit="return confirm('Сигурни ли сте, че искате да изтриете този запис за улов?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-row btn-row-danger">Изтрий</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </section>
}
