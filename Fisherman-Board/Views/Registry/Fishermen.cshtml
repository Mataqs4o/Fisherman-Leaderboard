@model IEnumerable<Fisherman_Board.Models.Person>
@{
    ViewData["Title"] = "Fisherman";
    var search = ViewData["Search"]?.ToString() ?? string.Empty;
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Таблица 1</span>
        <h1>Fisherman</h1>
    </div>
    <p>Таблица с рибари и основните им персонални атрибути.</p>
</section>

<section class="toolbar-card">
    <form class="search-form" method="get">
        <input type="search" name="search" value="@search" placeholder="Търсене по име" />
        <button type="submit" class="btn btn-primary-soft">Търси</button>
        <a class="btn btn-ghost" asp-action="Fishermen">Изчисти</a>
    </form>
    <div class="toolbar-actions">
        <a class="btn btn-primary-soft" asp-action="CreateFisherman">Добави fisherman</a>
        <a class="btn btn-ghost" asp-action="Index">Назад</a>
    </div>
</section>

@if (!Model.Any())
{
    <section class="content-card empty-state-card">
        <h2>Няма записи</h2>
        <p>Добавете първия fisherman в таблицата.</p>
    </section>
}
else
{
    <section class="table-card">
        <table class="table table-app">
            <thead>
                <tr>
                    <th>Име</th>
                    <th>Раждане</th>
                    <th>Пенсионер</th>
                    <th>С увреждане</th>
                    <th>TELK</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var person in Model)
            {
                <tr>
                    <td>@person.FullName</td>
                    <td>@person.BirthDate.ToString("dd.MM.yyyy")</td>
                    <td>@(person.IsPensioner ? "Да" : "Не")</td>
                    <td>@(person.IsDisabled ? "Да" : "Не")</td>
                    <td>@(string.IsNullOrWhiteSpace(person.TelkNumber) ? "-" : person.TelkNumber)</td>
                    <td>
                        <div class="table-actions">
                            <a class="btn btn-row" asp-action="EditFisherman" asp-route-id="@person.Id">Редакция</a>
                            <form asp-action="DeleteFisherman" asp-route-id="@person.Id" method="post" onsubmit="return confirm('Сигурни ли сте, че искате да изтриете този fisherman?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-row btn-row-danger">Изтрий</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </section>
}
