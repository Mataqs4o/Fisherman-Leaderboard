@model IEnumerable<Fisherman_Board.Models.Engine>
@{
    ViewData["Title"] = "Регистър двигатели";
    var search = ViewData["Search"]?.ToString() ?? string.Empty;
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Регистър</span>
        <h1>Двигатели</h1>
    </div>
    <p>Управление на двигатели, използвани при корабите и въглеродните изчисления.</p>
</section>

<section class="toolbar-card">
    <form class="search-form" method="get">
        <input type="search" name="search" value="@search" placeholder="Търсене по тип или гориво" />
        <button type="submit" class="btn btn-primary-soft">Търси</button>
        <a class="btn btn-ghost" asp-action="Engines">Изчисти</a>
    </form>
    <div class="toolbar-actions">
        <a class="btn btn-primary-soft" asp-action="CreateEngine">Добави двигател</a>
        <a class="btn btn-ghost" asp-action="Index">Назад</a>
    </div>
</section>

@if (!Model.Any())
{
    <section class="content-card empty-state-card">
        <h2>Няма записи</h2>
        <p>Добавете първия двигател, за да започнете да изграждате регистъра.</p>
    </section>
}
else
{
    <section class="table-card">
        <table class="table table-app">
            <thead>
                <tr>
                    <th>Тип</th>
                    <th>Гориво</th>
                    <th>Мощност</th>
                    <th>Разход</th>
                    <th>Кораби</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var engine in Model)
            {
                <tr>
                    <td>@engine.Type</td>
                    <td>@engine.FuelType</td>
                    <td>@engine.PowerKw.ToString("F0") kW</td>
                    <td>@engine.AvgFuelPerHour.ToString("F2") л/ч</td>
                    <td>@engine.Vessels.Count</td>
                    <td>
                        <div class="table-actions">
                            <a class="btn btn-row" asp-action="EditEngine" asp-route-id="@engine.Id">Редакция</a>
                            <form asp-action="DeleteEngine" asp-route-id="@engine.Id" method="post" onsubmit="return confirm('Сигурни ли сте, че искате да изтриете този двигател?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-row btn-row-danger">Изтрий</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </section>
}
